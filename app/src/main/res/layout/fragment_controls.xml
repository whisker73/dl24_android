<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Power ON/OFF -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="LAST-STEUERUNG" android:textSize="10sp" android:textColor="@color/text_muted"
                android:textStyle="bold" android:letterSpacing="0.05" android:layout_marginBottom="8dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button android:id="@+id/btnOutputOn"
                    android:layout_width="0dp" android:layout_height="48dp"
                    android:layout_weight="1" android:text="ON"
                    android:textSize="16sp" android:textStyle="bold"
                    android:backgroundTint="@color/green_on"
                    android:layout_marginEnd="6dp" android:enabled="false" />
                <Button android:id="@+id/btnOutputOff"
                    android:layout_width="0dp" android:layout_height="48dp"
                    android:layout_weight="1" android:text="OFF"
                    android:textSize="16sp" android:textStyle="bold"
                    android:backgroundTint="@color/red_off"
                    android:enabled="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- Direktsteuerung Sliders -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DIREKTSTEUERUNG" android:textSize="10sp" android:textColor="@color/text_muted"
                android:textStyle="bold" android:layout_marginBottom="8dp" />

            <!-- Current slider -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                    android:text="I:" android:textColor="@color/text_secondary" />
                <SeekBar android:id="@+id/seekbarCurrent"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:enabled="false" />
                <TextView android:id="@+id/labelCurrentValue"
                    android:layout_width="60dp" android:layout_height="wrap_content"
                    android:text="1.00 A" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:gravity="end" />
            </LinearLayout>

            <!-- Cutoff slider -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                    android:text="V-Cut:" android:textColor="@color/text_secondary" android:textSize="11sp" />
                <SeekBar android:id="@+id/seekbarCutoff"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:enabled="false" />
                <TextView android:id="@+id/labelCutoffValue"
                    android:layout_width="60dp" android:layout_height="wrap_content"
                    android:text="3.0 V" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:gravity="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- LiPo Profile -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="LIPO PROFILE" android:textSize="10sp" android:textColor="@color/text_muted"
                android:textStyle="bold" android:layout_marginBottom="6dp" />

            <Spinner android:id="@+id/spinnerLipoProfile"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:enabled="false" />

            <TextView android:id="@+id/labelDevicePreset"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Gerät: —" android:textColor="@color/accent_cyan"
                android:textSize="10sp" android:textStyle="italic"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Reset -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="RESET" android:textSize="10sp" android:textColor="@color/text_muted"
                android:textStyle="bold" android:layout_marginBottom="8dp" />

            <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:columnCount="2" android:rowCount="2" android:useDefaultMargins="true">

                <Button android:id="@+id/btnResetWh"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:text="W·h"
                    android:enabled="false" android:layout_margin="2dp" />

                <Button android:id="@+id/btnResetAh"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:text="A·h"
                    android:enabled="false" android:layout_margin="2dp" />

                <Button android:id="@+id/btnResetDuration"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:text="Dauer"
                    android:enabled="false" android:layout_margin="2dp" />

                <Button android:id="@+id/btnResetAll"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:text="Alles"
                    android:backgroundTint="@color/red_off"
                    android:enabled="false" android:layout_margin="2dp" />
            </GridLayout>
        </LinearLayout>

        <!-- Auto-Off Timer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AUTO-AUS TIMER" android:textSize="10sp" android:textColor="@color/text_muted"
                android:textStyle="bold" android:layout_marginBottom="4dp" />

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Gerät schaltet Last automatisch aus. 0 = deaktiviert."
                android:textColor="@color/text_muted" android:textSize="10sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Sekunden: " android:textColor="@color/text_secondary" />

                <EditText android:id="@+id/editTimerSeconds"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:inputType="number"
                    android:hint="0" android:text="0"
                    android:enabled="false"
                    android:textColor="@color/text_primary"
                    android:layout_marginEnd="8dp" />

                <Button android:id="@+id/btnTimerApply"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Setzen" android:enabled="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- Data Management -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DATEN" android:textSize="10sp" android:textColor="@color/text_muted"
                android:textStyle="bold" android:layout_marginBottom="8dp" />

            <Button android:id="@+id/btnExportCsv"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="CSV Exportieren"
                android:backgroundTint="@color/accent_blue"
                android:layout_marginBottom="6dp" />

            <Button android:id="@+id/btnClearData"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Daten löschen" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
